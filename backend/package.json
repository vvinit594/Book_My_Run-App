  "private": true,
  "description": "BookMyRun backend API (Node + Express + TypeScript + Prisma)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
