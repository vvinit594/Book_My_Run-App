{
  "name": "bookmyrun-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "frontend": "npm --workspace frontend start",
    "backend": "npm --workspace backend run dev",
    "dev": "concurrently -n frontend,backend -c magenta,cyan \"npm run frontend\" \"npm run backend\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
